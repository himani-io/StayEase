<% layout("layouts/boilerplate") %>
    <h3>Edit your Listing :</h3>
<div class="row">
  <div class="col-8 offset-2">
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT" novalidate class="needs-validation">
        <div>
           <label for="title" class="form-label">Title :</label>
           <input id="title" name="listing[title]" type="text" value="<%= listing.title %>" class="form-control" required>
           <div class="valid-feedback">Looks good!</div>
           <br/><br/>
        </div>
        
        <div>
           <label for="description" class="form-label">Description :</label>
           <input id="description" name="listing[description]" type="text" value="<%= listing.description %>" class="form-control" required>
           <div class="invalid-feedback">Description should be valid</div>
           <br/><br/>
        </div>

        <div>
           <label for="image" class="form-label">Image :</label>
           <input id="image" name="listing[image][url]" type="text" placeholder="enter image url" class="form-control" required>
           <div class="invalid-feedback">Image should be valid</div>
           <br/><br/>
        </div>
        
        <div>
           <label for="location" class="form-label">Location :</label>
           <input id="location" name="listing[location]" type="text" value="<%= listing.location %>" class="form-control" required>
           <div class="invalid-feedback">Location should be valid</div>
           <br/><br/>
        </div>
        
        <div class="row">
             <div class="col-md-4">
              <label for="price" class="form-label">Price :</label>
              <input id="price" name="listing[price]" type="number" value="<%= listing.price %>" class="form-control" required>
              <div class="invalid-feedback">Price should be valid</div>
              <br/><br/>
           </div>
            <div class="col-md-8">
              <label for="country" class="form-label">Country :</label>
              <input id="country" name="listing[country]" type="text" value="<%= listing.country %>" class="form-control" required>
              <div class="invalid-feedback">Country should be valid</div>
              <br/><br/>
            </div>
        </div>
        <button class="btn btn-dark add-btn edit-btn">Save</button>
        <br><br>
    </form>
  </div>
</div>