<% layout("layouts/boilerplate") %> 

<style>
   #filters{
      display: flex;
      flex-wrap: nowrap;
      align-items: center;
      overflow-x: auto;
      scrollbar-width: none; 
      position: sticky;    
      top: 4rem;
      z-index: 999;
      background: white; 
      padding: 1rem 0;
      border-bottom: 1px solid #e9ecef;
   }

   #filters::-webkit-scrollbar{
      display: none;          /* Chrome/Safari */
   }

   .filter{
      flex: 0 0 auto;
      text-align: center;
      margin-right: 1rem;
      margin-top: 1rem;
      opacity:0.7;
      padding: 0.5rem 0.8rem;
      border-radius: 12px;
      transition: all 0.2s ease;
   }

   .filter:hover{
      opacity: 1;
      cursor: pointer;
      background-color: #f8f9fa;
      transform: translateY(-2px);
   }

   .filter p {
      font-size: 0.8rem;
      margin: 0.2rem 0 0 0;
   }

   .filter-a {
      text-decoration: none;
      color: inherit;
   }

   .tax-toggle{
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-left: auto;
      margin-right: 1rem;
      padding: 0.6rem 1rem;
      border: 1px solid #161717;
      height: 3rem;
      border-radius: 14px;
      background-color: #f8f9fa;
      white-space: nowrap;
   }

   .tax-toggle .form-check-label{
      font-size: 0.9rem;
      font-weight: 500;
      margin-right: 0.5rem;
      cursor: pointer;
   }

   .tax-toggle .form-check-input{
      cursor: pointer;
      transform: scale(1.1);
   }

   .tax-info {
      display: none;
      color: #198754;
      font-weight: 500;
      font-size: 0.9rem;
   }

   .search-alert{
      position: fixed;
      top: 5rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 2000;
      min-width: 320px;
      max-width: 90%;
      text-align: center;
      border-radius: 12px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.12);
      padding: 0.8rem 1rem;
      background: white;
      font-weight: 500;
   }

   .found{
      background: white;
      color: #198754;
      border: 1px solid #d1e7dd;
   }

   .not-found{
      background: white;
      color: #856404;
      border: 1px solid #ffe69c;
   }

</style>

   <% if(message) { %>
         <div class="flash-msg search-alert <%= messageType === 'warning' ? 'not-found' : 'found' %>">
         <%= message %>
      </div>
   <% } %>

   <div id="filters">

      <div class="filter">
         <a href="/listings" class="filter-a">
           <div><i class="fa-solid fa-border-all"></i></div>
           <p>All</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Trending" class="filter-a">
           <div><i class="fa-solid fa-fire"></i></div>
           <p>Trending</p>
         </a>
      </div>

       <div class="filter">
         <a href="/listings?category=Beach" class="filter-a">
            <div><i class="fa-solid fa-umbrella"></i></div>
            <p>Beach</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Rooms" class="filter-a">
            <div><i class="fa-solid fa-bed"></i></div> 
            <p>Rooms</p>
        </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Iconic-Cities" class="filter-a">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic-Cities</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Mountains" class="filter-a">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Arctic" class="filter-a">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Pools" class="filter-a">
            <div><i class="fa-solid fa-water"></i></div>
            <p>Pools</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Forest" class="filter-a">
            <div><i class="fa-solid fa-tree"></i></div>
            <p>Forest</p>
         </a>
       </div>

      <div class="filter">
         <a href="/listings?category=Camping" class="filter-a">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Cabins" class="filter-a">
            <div><i class="fa-solid fa-house"></i></div>
            <p>Cabins</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Castles" class="filter-a">
            <div><i class="fa-solid fa-chess-rook"></i></div>
            <p>Castles</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Lakefront" class="filter-a">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Lakefront</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Farm Stay" class="filter-a">
            <div><i class="fa-solid fa-tractor"></i></div>
            <p>Farm Stay</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Pet Friendly" class="filter-a">
            <div><i class="fa-solid fa-paw"></i></div>
            <p>Pet Friendly</p>
         </a>
      </div>

      <div class="filter">
         <a href="/listings?category=Luxury" class="filter-a">
            <div><i class="fa-solid fa-star"></i></div>
            <p>Luxury</p>
         </a>
      </div>

      <div class="tax-toggle">
         <div class="form-check-reverse form-switch ">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
         </div> 
      </div>
      
   </div>

  
   <% if(allListings.length === 0 && search) { %>
         <div class="text-center mt-4">
           <h5>No stays found</h5>
           <p class="text-muted">Try another destination or keyword.</p>
         </div>
   <% } %>

   <div class="row row-cols-lg-3 row-cols-md-3 row-cols-sm-1 mt-3">
      <% for(let listing of allListings){ %>
         <a href="/listings/<%= listing._id %>" class="listing-link">
            <div class="card listing-card col">
               <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1570129477492-45c003edd2be?q=80&w=1000' %>" class="card-img-top" style="height: 20rem"  alt="listing_image">
               <div class="card-img-overlay">
                  <h5 class="card-title"></h5>
                  <p class="card-text"></p>
                  <p class="card-text"><small></small></p>
               </div>
               <div class="card-body">
                 <p class="card-text">
                    <b><%= listing.title %></b> <br/>
                    &#8377; <%= listing.price?.toLocaleString("en-IN") %> /night
                    <i class="tax-info">&nbsp; +18% GST</i>
                  </p>
               </div>
            </div>
         </a>
      <% } %>
   </div>
         
   <script>
      let taxSwitch = document.getElementById('switchCheckDefault');
      taxSwitch.addEventListener("click", () => {
         let taxInfo = document.getElementsByClassName("tax-info");
         for(let info of taxInfo){
            if(info.style.display != "inline") {
               info.style.display = "inline";
            }else {
               info.style.display = "none";
            }  
         }
      } )
   </script>
    

   