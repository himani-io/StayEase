<% layout("layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-2">
    <br>
    <h3>Add new Listing :</h3>
    <hr>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div>
           <label for="title" class="form-label">Title :</label>
           <input id="title" name="listing[title]" type="text" placeholder="add a catchy title" class="form-control" required>
           <div class="valid-feedback">Looks good!</div>
           <br/><br/>
        </div>
       
        <div>
           <label for="description" class="form-label">Description :</label>
           <textarea id="description" name="listing[description]" type="text" placeholder="enter description" class="form-control" required></textarea>
           <div class="invalid-feedback">Description should be valid</div>
           <br/><br/>
        </div>

        <div>
           <label for="category" class="form-label">Category :</label>
           <select name="listing[category]" id="category" class="form-select" required>
              <option value="" disabled selected>Select Category</option>
              <option value="Trending">Trending</option>
              <option value="Beach">Beach</option>
              <option value="Rooms">Rooms</option>
              <option value="Iconic-Cities">Iconic-Cities</option>
              <option value="Mountains">Mountains</option>
              <option value="Arctic">Arctic</option>
              <option value="Pools">Pools</option>
              <option value="Forest">Forest</option>
              <option value="Camping">Camping</option>
              <option value="Cabins">Cabins</option>
              <option value="Castles">Castles</option>
              <option value="Lakefront">Lakefront</option>
              <option value="Farm Stay">Farm Stay</option>
              <option value="Pet Friendly">Pet Friendly</option>
              <option value="Luxury">Luxury</option>
           </select>
           <div class="invalid-feedback">Description should be valid</div>
           <br/><br/>
        </div>
        
        <div>
           <label for="image" class="form-label">Upload Image :</label>
           <input id="image" name="listing[image]" type="file"  class="form-control" accept="image/*" >
           <br/><br/>
        </div>
        
        <div>
           <label for="location" class="form-label">Location :</label>
           <input id="location" name="listing[location]" type="text" placeholder="eg.. Maldives" class="form-control" required>
           <div class="invalid-feedback">Location should be valid</div>
           <br/><br/>
        </div>
        
        <div class="row">
          <div class="col-md-4">
            <label for="price" class="form-label">Price :</label>
            <input id="price" name="listing[price]" type="number"  placeholder="1200" class="form-control" required>
            <div class="invalid-feedback">Price should be valid!</div>
            <br/><br/>
          </div>
          <div class="col-md-8">
            <label for="country" class="form-label" class="form-label">Country :</label>
            <input id="country" name="listing[country]" type="text" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">Country should be valid</div>
            <br/><br/>
          </div>
        </div>
        
        <button class="btn btn-dark add-btn">Add</button>
        <br><br>
    </form>
  </div>
</div>

